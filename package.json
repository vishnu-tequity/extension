{
  "name": "ai-hover-explainer",
  "displayName": "AI Hover Explainer",
  "description": "AI-powered symbol explanations on hover, powered by local Ollama (no API key, no internet needed)",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiHover.setApiKey",
        "title": "AI Hover: Settings"
      }
    ],
    "configuration": {
      "title": "AI Hover Explainer",
      "properties": {
        "aiHover.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable AI hover explanations"
        },
        "aiHover.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "Ollama server URL (e.g. http://192.168.1.100:11434/v1 for a shared office server)"
        },
        "aiHover.model": {
          "type": "string",
          "default": "codellama",
          "description": "Ollama model to use for explanations (e.g. codellama, llama3, mistral)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "ai": "^6.0.164"
  }
}
